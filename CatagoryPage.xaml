<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    
    xmlns:local="clr-namespace:MCQS"
    x:Class="MCQS.CategoryPage"
    Shell.NavBarIsVisible="False">
    <Grid
        RowDefinitions="Auto,*,Auto">
        <!-- ── Header ── -->
        <Grid
            Grid.Row="0"
            Padding="20,54,20,16"
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="12">
            <Border
                Grid.Column="0"
                BackgroundColor="{StaticResource CardBackground}"
                StrokeThickness="0"
                HeightRequest="40"
                WidthRequest="40"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle
                        CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="{StaticResource ShadowSubtleBrush}"
                        Offset="0,3"
                        Radius="8" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Label
                    Text="←"
                    FontSize="20"
                    TextColor="{StaticResource TextPrimary}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>
            <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                VerticalOptions="Center">
                <Label
                    x:Name="CategoryTitle"
                    Style="{StaticResource AppTitleLabel}"
                    FontSize="22"
                    LineBreakMode="TailTruncation" />
                <Label
                    x:Name="StatsLabel"
                    Style="{StaticResource SubtitleLabel}" />
            </VerticalStackLayout>
            <Border
                Grid.Column="2"
                Style="{StaticResource FabButton}"
                HorizontalOptions="End">
                <Border.Shadow>
                    <Shadow
                        Brush="{StaticResource ShadowStrongBrush}"
                        Offset="0,5"
                        Radius="10" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnAddPdfTapped" />
                </Border.GestureRecognizers>
                <Label
                    Text="+"
                    FontSize="26"
                    TextColor="{StaticResource White}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>
        </Grid>
        <!-- ── Body ── -->
        <Grid
            Grid.Row="1">
            <!-- Empty State -->
            <VerticalStackLayout
                x:Name="EmptyState"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="12"
                IsVisible="True">
                <Label
                    Text="📄"
                    FontSize="64"
                    Opacity="0.5"
                    HorizontalOptions="Center" />
                <Label
                    Text="No PDFs yet"
                    Style="{StaticResource EmptyStateHeadingLabel}" />
                <Label
                    Text="Tap + to add your first PDF"
                    Style="{StaticResource EmptyStateHintLabel}" />
            </VerticalStackLayout>
            <!-- PDF List -->
            <ScrollView
                x:Name="PdfScrollView"
                IsVisible="False">
                <CollectionView
                    x:Name="PdfList"
                    Margin="20,8">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Style="{StaticResource Card}"
                                Margin="0,0,0,12">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="{StaticResource ShadowSubtleBrush}"
                                        Offset="0,3"
                                        Radius="8" />
                                </Border.Shadow>
                                <Grid
                                    ColumnDefinitions="48,*,Auto"
                                    ColumnSpacing="12">
                                    <!-- Icon -->
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="{StaticResource IconBadgeBackground}"
                                        StrokeThickness="0"
                                        HeightRequest="48"
                                        WidthRequest="48"
                                        VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle
                                                CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Label
                                            Text="📄"
                                            FontSize="24"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <!-- Name + status -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="4"
                                        VerticalOptions="Center">
                                        <Label
                                            Text="{Binding FileName}"
                                            Style="{StaticResource CardTitleLabel}"
                                            FontSize="14" />
                                        <Label
                                            Text="{Binding StatusLabel}"
                                            Style="{StaticResource MetaLabel}" />
                                    </VerticalStackLayout>
                                    <!-- Remove -->
                                    <Border
                                        Grid.Column="2"
                                        BackgroundColor="#FFF0F0"
                                        StrokeThickness="0"
                                        HeightRequest="34"
                                        WidthRequest="34"
                                        VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle
                                                CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Tapped="OnRemovePdfTapped"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label
                                            Text="✕"
                                            FontSize="14"
                                            TextColor="#E53935"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </Grid>
        <!-- ── Footer ── -->
        <Grid
            Grid.Row="2"
            Padding="20,12,20,36"
            BackgroundColor="{StaticResource PageBackground}">
            <BoxView
                HeightRequest="1"
                BackgroundColor="{StaticResource Gray100}"
                VerticalOptions="Start"
                Margin="-20,0" />
            <Button
                x:Name="StartQuizButton"
                Text="🚀  Start Quiz"
                Style="{StaticResource PrimaryButton}"
                Margin="0,12,0,0"
                Clicked="OnStartQuizTapped"
                IsEnabled="False" />
        </Grid>
    </Grid>
</ContentPage>