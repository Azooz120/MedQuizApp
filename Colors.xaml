<?xml version="1.0" encoding="utf-8"?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <!-- ═══════════════════════════════════════════════
         BRAND / ACCENT (Modern Indigo)
    ═══════════════════════════════════════════════ -->
    <Color
        x:Key="Primary">#4F46E5</Color>
    <Color
        x:Key="PrimaryDark">#6366F1</Color>
    <Color
        x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color
        x:Key="Secondary">#EEF2FF</Color>
    <Color
        x:Key="SecondaryDarkText">#818CF8</Color>
    <Color
        x:Key="Tertiary">#312E81</Color>
    <!-- ═══════════════════════════════════════════════
         BACKGROUND
    ═══════════════════════════════════════════════ -->
    <Color
        x:Key="PageBackground">#F9FAFB</Color>
    <Color
        x:Key="CardBackground">#FFFFFF</Color>
    <Color
        x:Key="IconBadgeBackground">#EEF2FF</Color>
    <!-- ═══════════════════════════════════════════════
         TEXT
    ═══════════════════════════════════════════════ -->
    <Color
        x:Key="TextPrimary">#0F172A</Color>
    <Color
        x:Key="TextHeading">#020617</Color>
    <Color
        x:Key="TextBody">#1E293B</Color>
    <Color
        x:Key="TextMuted">#64748B</Color>
    <Color
        x:Key="TextHint">#94A3B8</Color>
    <Color
        x:Key="TextDisabled">#CBD5F5</Color>
    <!-- ═══════════════════════════════════════════════
         SHADOWS
    ═══════════════════════════════════════════════ -->
    <Color
        x:Key="ShadowStrong">#22000000</Color>
    <Color
        x:Key="ShadowSubtle">#12000000</Color>
    <!-- ═══════════════════════════════════════════════
         NEUTRALS
    ═══════════════════════════════════════════════ -->
    <Color
        x:Key="White">#FFFFFF</Color>
    <Color
        x:Key="Black">#000000</Color>
    <Color
        x:Key="OffBlack">#0B0F19</Color>
    <Color
        x:Key="Gray100">#F1F5F9</Color>
    <Color
        x:Key="Gray200">#E2E8F0</Color>
    <Color
        x:Key="Gray300">#CBD5E1</Color>
    <Color
        x:Key="Gray400">#94A3B8</Color>
    <Color
        x:Key="Gray500">#64748B</Color>
    <Color
        x:Key="Gray600">#475569</Color>
    <Color
        x:Key="Gray900">#0F172A</Color>
    <Color
        x:Key="Gray950">#020617</Color>
    <!-- ═══════════════════════════════════════════════
         BRUSHES
    ═══════════════════════════════════════════════ -->
    <SolidColorBrush
        x:Key="PrimaryBrush"
        Color="{StaticResource Primary}" />
    <SolidColorBrush
        x:Key="SecondaryBrush"
        Color="{StaticResource Secondary}" />
    <SolidColorBrush
        x:Key="TertiaryBrush"
        Color="{StaticResource Tertiary}" />
    <SolidColorBrush
        x:Key="PageBackgroundBrush"
        Color="{StaticResource PageBackground}" />
    <SolidColorBrush
        x:Key="CardBackgroundBrush"
        Color="{StaticResource CardBackground}" />
    <SolidColorBrush
        x:Key="IconBadgeBackgroundBrush"
        Color="{StaticResource IconBadgeBackground}" />
    <SolidColorBrush
        x:Key="WhiteBrush"
        Color="{StaticResource White}" />
    <SolidColorBrush
        x:Key="BlackBrush"
        Color="{StaticResource Black}" />
    <SolidColorBrush
        x:Key="ShadowStrongBrush"
        Color="{StaticResource ShadowStrong}" />
    <SolidColorBrush
        x:Key="ShadowSubtleBrush"
        Color="{StaticResource ShadowSubtle}" />
    <SolidColorBrush
        x:Key="Gray100Brush"
        Color="{StaticResource Gray100}" />
    <SolidColorBrush
        x:Key="Gray200Brush"
        Color="{StaticResource Gray200}" />
    <SolidColorBrush
        x:Key="Gray300Brush"
        Color="{StaticResource Gray300}" />
    <SolidColorBrush
        x:Key="Gray400Brush"
        Color="{StaticResource Gray400}" />
    <SolidColorBrush
        x:Key="Gray500Brush"
        Color="{StaticResource Gray500}" />
    <SolidColorBrush
        x:Key="Gray600Brush"
        Color="{StaticResource Gray600}" />
    <SolidColorBrush
        x:Key="Gray900Brush"
        Color="{StaticResource Gray900}" />
    <SolidColorBrush
        x:Key="Gray950Brush"
        Color="{StaticResource Gray950}" />
</ResourceDictionary>