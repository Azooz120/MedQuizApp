<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MCQS.QuizPage"
    Shell.NavBarIsVisible="False">
    <Grid
        RowDefinitions="Auto,*,Auto"
        Padding="20,54,20,36">
        <!-- ── Header: Progress ── -->
        <Grid
            Grid.Row="0"
            RowDefinitions="Auto,Auto"
            RowSpacing="12">
            <!-- Question counter + exit -->
            <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto">
                <!-- Exit button -->
                <Border
                    Grid.Column="0"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0"
                    HeightRequest="40"
                    WidthRequest="40"
                    VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle
                            CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="{StaticResource ShadowSubtleBrush}"
                            Offset="0,3"
                            Radius="8" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnExitTapped" />
                    </Border.GestureRecognizers>
                    <Label
                        Text="✕"
                        FontSize="16"
                        TextColor="{StaticResource TextMuted}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
                <!-- Question number -->
                <Label
                    Grid.Column="1"
                    x:Name="QuestionNumberLabel"
                    Text="Question 1 of 10"
                    Style="{StaticResource SubtitleLabel}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                <!-- Score badge -->
                <Border
                    Grid.Column="2"
                    BackgroundColor="{StaticResource IconBadgeBackground}"
                    StrokeThickness="0"
                    HeightRequest="40"
                    WidthRequest="60"
                    VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle
                            CornerRadius="14" />
                    </Border.StrokeShape>
                    <Label
                        x:Name="ScoreLabel"
                        Text="0 ✓"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
            </Grid>
            <!-- Progress bar -->
            <Border
                Grid.Row="1"
                BackgroundColor="{StaticResource IconBadgeBackground}"
                StrokeThickness="0"
                HeightRequest="8">
                <Border.StrokeShape>
                    <RoundRectangle
                        CornerRadius="4" />
                </Border.StrokeShape>
                <Border
                    x:Name="ProgressFill"
                    BackgroundColor="{StaticResource Primary}"
                    StrokeThickness="0"
                    HeightRequest="8"
                    HorizontalOptions="Start"
                    WidthRequest="0">
                    <Border.StrokeShape>
                        <RoundRectangle
                            CornerRadius="4" />
                    </Border.StrokeShape>
                </Border>
            </Border>
        </Grid>
        <!-- ── Body: Question + Options ── -->
        <ScrollView
            Grid.Row="1"
            Margin="0,24,0,0">
            <VerticalStackLayout
                Spacing="16">
                <!-- Question card -->
                <Border
                    Style="{StaticResource Card}">
                    <Border.Shadow>
                        <Shadow
                            Brush="{StaticResource ShadowSubtleBrush}"
                            Offset="0,4"
                            Radius="12" />
                    </Border.Shadow>
                    <VerticalStackLayout
                        Spacing="8">
                        <Label
                            Text="QUESTION"
                            FontSize="11"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"
                            CharacterSpacing="1.2" />
                        <Label
                            x:Name="QuestionLabel"
                            Style="{StaticResource SectionHeadingLabel}"
                            FontSize="16"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>
                <!-- Option buttons -->
                <VerticalStackLayout
                    x:Name="OptionsLayout"
                    Spacing="12">
                    <Border
                        x:Name="Option0"
                        Style="{StaticResource OptionCard}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Tapped="OnOptionTapped"
                                CommandParameter="0" />
                        </Border.GestureRecognizers>
                        <Grid
                            ColumnDefinitions="36,*"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                x:Name="Badge0"
                                Style="{StaticResource OptionBadge}">
                                <Label
                                    Text="A"
                                    Style="{StaticResource OptionBadgeLabel}" />
                            </Border>
                            <Label
                                Grid.Column="1"
                                x:Name="OptionLabel0"
                                Style="{StaticResource OptionText}"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border
                        x:Name="Option1"
                        Style="{StaticResource OptionCard}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Tapped="OnOptionTapped"
                                CommandParameter="1" />
                        </Border.GestureRecognizers>
                        <Grid
                            ColumnDefinitions="36,*"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                x:Name="Badge1"
                                Style="{StaticResource OptionBadge}">
                                <Label
                                    Text="B"
                                    Style="{StaticResource OptionBadgeLabel}" />
                            </Border>
                            <Label
                                Grid.Column="1"
                                x:Name="OptionLabel1"
                                Style="{StaticResource OptionText}"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border
                        x:Name="Option2"
                        Style="{StaticResource OptionCard}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Tapped="OnOptionTapped"
                                CommandParameter="2" />
                        </Border.GestureRecognizers>
                        <Grid
                            ColumnDefinitions="36,*"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                x:Name="Badge2"
                                Style="{StaticResource OptionBadge}">
                                <Label
                                    Text="C"
                                    Style="{StaticResource OptionBadgeLabel}" />
                            </Border>
                            <Label
                                Grid.Column="1"
                                x:Name="OptionLabel2"
                                Style="{StaticResource OptionText}"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border
                        x:Name="Option3"
                        Style="{StaticResource OptionCard}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Tapped="OnOptionTapped"
                                CommandParameter="3" />
                        </Border.GestureRecognizers>
                        <Grid
                            ColumnDefinitions="36,*"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                x:Name="Badge3"
                                Style="{StaticResource OptionBadge}">
                                <Label
                                    Text="D"
                                    Style="{StaticResource OptionBadgeLabel}" />
                            </Border>
                            <Label
                                Grid.Column="1"
                                x:Name="OptionLabel3"
                                Style="{StaticResource OptionText}"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
                <!-- Explanation card (hidden until answered) -->
                <Border
                    x:Name="ExplanationCard"
                    Style="{StaticResource Card}"
                    IsVisible="False"
                    Margin="0,4,0,0">
                    <Border.Shadow>
                        <Shadow
                            Brush="{StaticResource ShadowSubtleBrush}"
                            Offset="0,4"
                            Radius="12" />
                    </Border.Shadow>
                    <VerticalStackLayout
                        Spacing="8">
                        <Label
                            Text="💡 EXPLANATION"
                            FontSize="11"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"
                            CharacterSpacing="1.2" />
                        <Label
                            x:Name="ExplanationLabel"
                            Style="{StaticResource SubtitleLabel}"
                            FontSize="14"
                            LineBreakMode="WordWrap"
                            TextColor="{StaticResource TextBody}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <!-- ── Footer: Next button ── -->
        <Grid
            Grid.Row="2"
            Margin="0,16,0,0">
            <Button
                x:Name="NextButton"
                Text="Next →"
                Style="{StaticResource PrimaryButton}"
                IsVisible="False"
                Clicked="OnNextTapped" />
        </Grid>
    </Grid>
</ContentPage>