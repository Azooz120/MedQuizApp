<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    
    xmlns:local="clr-namespace:MCQS"
    x:Class="MCQS.QuizSettingsPage"
    Shell.NavBarIsVisible="False">
    <Grid
        RowDefinitions="Auto,*,Auto">
        <!-- ── Header ── -->
        <Grid
            Grid.Row="0"
            Padding="20,54,20,16"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="12">
            <!-- Back button -->
            <Border
                Grid.Column="0"
                BackgroundColor="{StaticResource CardBackground}"
                StrokeThickness="0"
                HeightRequest="40"
                WidthRequest="40"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle
                        CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="{StaticResource ShadowSubtleBrush}"
                        Offset="0,3"
                        Radius="8" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Label
                    Text="←"
                    FontSize="20"
                    TextColor="{StaticResource TextPrimary}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>
            <!-- Title -->
            <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                VerticalOptions="Center">
                <Label
                    Text="Quiz Settings"
                    Style="{StaticResource AppTitleLabel}"
                    FontSize="22" />
                <Label
                    x:Name="CategorySubtitle"
                    Style="{StaticResource SubtitleLabel}" />
            </VerticalStackLayout>
        </Grid>
        <!-- ── Body ── -->
        <ScrollView
            Grid.Row="1">
            <VerticalStackLayout
                Padding="20,8,20,20"
                Spacing="16">
                <!-- ── Number of Questions ── -->
                <Label
                    Text="NUMBER OF QUESTIONS"
                    FontSize="11"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextDisabled}"
                    CharacterSpacing="1.2"
                    Margin="4,0,0,0" />
                <Border
                    Style="{StaticResource Card}">
                    <Border.Shadow>
                        <Shadow
                            Brush="{StaticResource ShadowSubtleBrush}"
                            Offset="0,3"
                            Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout
                        Spacing="16">
                        <!-- Selected count display -->
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                Text="Questions per quiz"
                                Style="{StaticResource CardTitleLabel}"
                                FontSize="15"
                                VerticalOptions="Center" />
                            <Border
                                Grid.Column="1"
                                BackgroundColor="{StaticResource IconBadgeBackground}"
                                StrokeThickness="0"
                                HeightRequest="38"
                                WidthRequest="52">
                                <Border.StrokeShape>
                                    <RoundRectangle
                                        CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label
                                    x:Name="QuestionCountLabel"
                                    Text="10"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource Primary}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>
                        <!-- Preset chips: 5 / 10 / 15 / 20 -->
                        <Grid
                            ColumnDefinitions="*,*,*,*"
                            ColumnSpacing="10">
                            <Border
                                Grid.Column="0"
                                x:Name="Chip5"
                                Style="{StaticResource ChipSelected}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnChipTapped"
                                        CommandParameter="5" />
                                </Border.GestureRecognizers>
                                <Label
                                    Text="5"
                                    Style="{StaticResource ChipLabelSelected}" />
                            </Border>
                            <Border
                                Grid.Column="1"
                                x:Name="Chip10"
                                Style="{StaticResource ChipSelected}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnChipTapped"
                                        CommandParameter="10" />
                                </Border.GestureRecognizers>
                                <Label
                                    Text="10"
                                    Style="{StaticResource ChipLabelSelected}" />
                            </Border>
                            <Border
                                Grid.Column="2"
                                x:Name="Chip15"
                                Style="{StaticResource ChipUnselected}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnChipTapped"
                                        CommandParameter="15" />
                                </Border.GestureRecognizers>
                                <Label
                                    Text="15"
                                    Style="{StaticResource ChipLabelUnselected}" />
                            </Border>
                            <Border
                                Grid.Column="3"
                                x:Name="Chip20"
                                Style="{StaticResource ChipUnselected}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnChipTapped"
                                        CommandParameter="20" />
                                </Border.GestureRecognizers>
                                <Label
                                    Text="20"
                                    Style="{StaticResource ChipLabelUnselected}" />
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <!-- ── Question Type ── -->
                <Label
                    Text="QUESTION TYPE"
                    FontSize="11"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextDisabled}"
                    CharacterSpacing="1.2"
                    Margin="4,8,0,0" />
                <!-- MCQ option (selected, only option for now) -->
                <Border
                    Style="{StaticResource Card}">
                    <Border.Shadow>
                        <Shadow
                            Brush="{StaticResource ShadowSubtleBrush}"
                            Offset="0,3"
                            Radius="8" />
                    </Border.Shadow>
                    <Grid
                        ColumnDefinitions="48,*,Auto"
                        ColumnSpacing="12">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource IconBadgeBackground}"
                            StrokeThickness="0"
                            HeightRequest="48"
                            WidthRequest="48"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle
                                    CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label
                                Text="🔤"
                                FontSize="24"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="3"
                            VerticalOptions="Center">
                            <Label
                                Text="Multiple Choice"
                                Style="{StaticResource CardTitleLabel}"
                                FontSize="15" />
                            <Label
                                Text="4 options · instant feedback"
                                Style="{StaticResource MetaLabel}" />
                        </VerticalStackLayout>
                        <!-- Checkmark -->
                        <Border
                            Grid.Column="2"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeThickness="0"
                            HeightRequest="26"
                            WidthRequest="26"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle
                                    CornerRadius="13" />
                            </Border.StrokeShape>
                            <Label
                                Text="✓"
                                FontSize="14"
                                TextColor="{StaticResource White}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>
                <!-- ── More options coming soon ── -->
                <Border
                    Style="{StaticResource Card}"
                    Opacity="0.45">
                    <Border.Shadow>
                        <Shadow
                            Brush="{StaticResource ShadowSubtleBrush}"
                            Offset="0,2"
                            Radius="6" />
                    </Border.Shadow>
                    <Grid
                        ColumnDefinitions="48,*"
                        ColumnSpacing="12">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource IconBadgeBackground}"
                            StrokeThickness="0"
                            HeightRequest="48"
                            WidthRequest="48"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle
                                    CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label
                                Text="✏️"
                                FontSize="24"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="3"
                            VerticalOptions="Center">
                            <Label
                                Text="True / False"
                                Style="{StaticResource CardTitleLabel}"
                                FontSize="15" />
                            <Label
                                Text="Coming soon"
                                Style="{StaticResource MetaLabel}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <!-- ── Footer ── -->
        <Grid
            Grid.Row="2"
            Padding="20,12,20,36"
            BackgroundColor="{StaticResource PageBackground}">
            <BoxView
                HeightRequest="1"
                BackgroundColor="{StaticResource Gray100}"
                VerticalOptions="Start"
                Margin="-20,0" />
            <Button
                Text="✨  Generate Quiz"
                Style="{StaticResource PrimaryButton}"
                Margin="0,12,0,0"
                Clicked="OnGenerateTapped" />
        </Grid>
    </Grid>
</ContentPage>