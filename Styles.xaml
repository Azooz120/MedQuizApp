            Value="{StaticResource ShadowSubtleBrush}" />
        <Setter
            Property="Offset"
            Value="0,4" />
    </Style>
    <Style
        TargetType="Slider">
        <Setter
            Property="MinimumTrackColor"
            Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        <Setter
