            Value="{StaticResource Primary}" />
        <Setter
            Property="BackgroundColor"
            Value="Transparent" />
        <Setter
            Property="FontFamily"
            Value="OpenSansRegular" />
        <Setter
            Property="FontSize"
            Value="14" />
        <Setter
            Property="MinimumHeightRequest"
            Value="44" />
        <Setter
            Property="MinimumWidthRequest"
            Value="44" />
        <Setter
            Property="VisualStateManager.VisualStateGroups">
